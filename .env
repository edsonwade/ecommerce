# ============================================================
# .env — Local development environment variables
# Never commit real secrets — use a secrets manager in production.
# ============================================================

# PostgreSQL
POSTGRES_USERNAME=vanilson
POSTGRES_PASSWORD=vanilson

# MongoDB
MONGO_USERNAME=vanilson
MONGO_PASSWORD=vanilson

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# JWT Secret (Base64-encoded 256-bit key — generate a new one for production)
# openssl rand -base64 32
JWT_SECRET=bXlTdXBlclNlY3VyZVNlY3JldEtleUZvckpXVEF1dGgxMjM0NTY3ODk=

# Gateway
GATEWAY_MAX_CONCURRENT=5000

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Eureka
EUREKA_HOST=discovery-service
